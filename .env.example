# Resend API key — used to send contact-form enquiries as email.
# Get one at https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Address enquiries get sent to
CONTACT_TO_EMAIL="you@murugesanco.com"

# Optional: verified sender address (defaults to Resend's shared onboarding address)
CONTACT_FROM_EMAIL="Murugesan & Co <onboarding@resend.dev>"

# Public site URL, used for metadata, sitemap and canonical URLs
NEXT_PUBLIC_SITE_URL="https://www.murugesanco.com"

# Optional: WhatsApp business number for the floating contact button (E.164, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER="919382701199"
